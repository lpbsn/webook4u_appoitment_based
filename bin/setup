#!/usr/bin/env ruby
require "erb"
require "fileutils"
require "open3"
require "psych"
require "cgi"
require "uri"

APP_ROOT = File.expand_path("..", __dir__)
EXPECTED_POSTGRES_MAJOR = 17

def system!(*args)
  system(*args, exception: true)
end

def abort_setup!(message)
  warn "\nSetup preflight failed: #{message}"
  exit 1
end

def capture!(*args, env: {})
  output, status = Open3.capture2e(env, *args)
  [output.strip, status]
end

def expected_ruby_version
  File.read(File.join(APP_ROOT, ".ruby-version")).strip
end

def expected_bundler_version
  lines = File.readlines(File.join(APP_ROOT, "Gemfile.lock"), chomp: true)
  bundled_with_index = lines.index("BUNDLED WITH")

  raise "Missing BUNDLED WITH in Gemfile.lock" unless bundled_with_index

  version = lines[bundled_with_index + 1].to_s.strip
  raise "Missing Bundler version in Gemfile.lock" if version.empty?

  version
end

def verify_ruby!
  expected = expected_ruby_version
  return if RUBY_VERSION == expected

  abort_setup!(
    "Ruby #{expected} is required, but #{RUBY_VERSION} is active. " \
    "Switch Ruby to #{expected} and rerun `bin/setup --skip-server`."
  )
end

def verify_bundler!
  expected = expected_bundler_version
  output, status = capture!("bundle", "-v")

  unless status.success?
    abort_setup!(
      "Bundler #{expected} is required, but `bundle -v` failed. " \
      "Install Bundler #{expected} and rerun `bin/setup --skip-server`.\n#{output}"
    )
  end

  actual = output[/\b(\d+\.\d+\.\d+)\b/, 1]

  if actual != expected
    abort_setup!(
      "Bundler #{expected} is required, but #{actual || 'an unknown version'} is active. " \
      "Run `gem install bundler:#{expected}` and rerun `bin/setup --skip-server`."
    )
  end
rescue Errno::ENOENT
  abort_setup!(
    "Bundler #{expected} is required, but `bundle` is not available on PATH. " \
    "Install Bundler #{expected} and rerun `bin/setup --skip-server`."
  )
end

def deep_stringify_keys(value)
  case value
  when Hash
    value.each_with_object({}) do |(key, nested_value), result|
      result[key.to_s] = deep_stringify_keys(nested_value)
    end
  when Array
    value.map { |nested_value| deep_stringify_keys(nested_value) }
  else
    value
  end
end

def parse_database_url(url)
  uri = URI.parse(url)
  query = uri.opaque ? uri.opaque.to_s.split("?", 2)[1] : uri.query

  attributes = parse_database_url_query(query)
  attributes["adapter"] ||= normalize_database_adapter(uri.scheme)

  unless uri.opaque
    attributes["username"] ||= uri.user
    attributes["password"] ||= uri.password
    attributes["port"] ||= uri.port if uri.port
    attributes["database"] ||= uri.path.to_s.sub(%r{\A/}, "")
    attributes["host"] ||= uri.hostname
  end

  attributes.reject { |_, value| value.nil? || value == "" }
end

def parse_database_url_query(query)
  CGI.parse(query.to_s).each_with_object({}) do |(key, values), result|
    value = values.last
    result[key] = value unless value.nil? || value.empty?
  end
end

def normalize_database_adapter(adapter)
  normalized = adapter.to_s.tr("-", "_")
  normalized == "postgres" ? "postgresql" : normalized
end

def merge_database_url(config, url)
  config
    .reject { |key, _| key == "url" }
    .merge(parse_database_url(url))
end

def resolve_development_database_config(raw_config, environment_url: nil)
  config =
    case raw_config
    when String
      parse_database_url(raw_config)
    when Hash
      raw_config
    else
      raise KeyError, "development config must be a Hash or URL string"
    end

  config = merge_database_url(config, config["url"]) if config["url"] && !config["url"].empty?
  config = merge_database_url(config, environment_url) if environment_url && !environment_url.empty?
  config
end

def development_database_config
  rendered = ERB.new(File.read(File.join(APP_ROOT, "config/database.yml"))).result
  yaml = Psych.safe_load(rendered, aliases: true) || {}
  raw_config = deep_stringify_keys(yaml.fetch("development"))
  resolve_development_database_config(raw_config, environment_url: ENV["DATABASE_URL"])
end

def verify_postgres!
  config = development_database_config
  adapter = config["adapter"]

  unless adapter == "postgresql" || adapter == "postgres"
    abort_setup!(
      "Expected a PostgreSQL development config, but adapter is #{adapter.inspect}. " \
      "Update DATABASE_URL or config/database.yml before rerunning `bin/setup --skip-server`."
    )
  end

  base_command = ["psql", "-X", "-At", "-F", "|"]
  base_command += ["-h", config["host"]] if config["host"] && !config["host"].empty?
  base_command += ["-p", config["port"].to_s] if config["port"]
  base_command += ["-U", config["username"]] if config["username"] && !config["username"].empty?

  env = {}
  env["PGPASSWORD"] = config["password"] if config["password"] && !config["password"].empty?

  candidate_databases = [config["database"], "postgres"].compact.reject(&:empty?).uniq
  output = nil
  status = nil

  candidate_databases.each do |database_name|
    output, status = capture!(
      *(base_command + ["-d", database_name, "-c", "SELECT current_setting('server_version'), current_setting('server_version_num');"]),
      env: env
    )
    break if status.success?
  end

  unless status&.success?
    abort_setup!(
      "Cannot reach the PostgreSQL server for the development config. " \
      "Start PostgreSQL #{EXPECTED_POSTGRES_MAJOR}.x locally or fix DATABASE_URL/config/database.yml, then rerun `bin/setup --skip-server`.\n#{output}"
    )
  end

  server_version, server_version_num = output.split("|", 2)
  server_major = server_version_num.to_i / 10_000

  return if server_major == EXPECTED_POSTGRES_MAJOR

  abort_setup!(
    "PostgreSQL server #{server_version} is connected, but #{EXPECTED_POSTGRES_MAJOR}.x is required. " \
    "Upgrade the local PostgreSQL server and rerun `bin/setup --skip-server`. " \
    "The client version alone is not enough."
  )
rescue Errno::ENOENT
  abort_setup!(
    "PostgreSQL #{EXPECTED_POSTGRES_MAJOR}.x is required, but `psql` is not available on PATH. " \
    "Install PostgreSQL #{EXPECTED_POSTGRES_MAJOR}.x locally and rerun `bin/setup --skip-server`."
  )
rescue Psych::SyntaxError, KeyError, URI::InvalidURIError => error
  abort_setup!(
    "Cannot resolve the development PostgreSQL config from DATABASE_URL/config/database.yml. " \
    "Fix the local database config and rerun `bin/setup --skip-server`.\n#{error.message}"
  )
end

def run_preflight!
  puts "== Checking local prerequisites =="
  verify_ruby!
  verify_bundler!
  verify_postgres!
end

if $PROGRAM_NAME == __FILE__
  FileUtils.chdir APP_ROOT do
    # This script is a way to set up or update your development environment automatically.
    # This script is idempotent, so that you can run it at any time and get an expectable outcome.
    # Add necessary setup steps to this file.

    run_preflight!

    puts "== Installing dependencies =="
    system("bundle check") || system!("bundle install")

    # puts "\n== Copying sample files =="
    # unless File.exist?("config/database.yml")
    #   FileUtils.cp "config/database.yml.sample", "config/database.yml"
    # end

    puts "\n== Preparing database =="
    system! "bin/rails db:prepare"
    system! "bin/rails db:reset" if ARGV.include?("--reset")

    puts "\n== Removing old logs and tempfiles =="
    system! "bin/rails log:clear tmp:clear"

    unless ARGV.include?("--skip-server")
      puts "\n== Starting development server =="
      STDOUT.flush # flush the output before exec(2) so that it displays
      exec "bin/dev"
    end
  end
end
