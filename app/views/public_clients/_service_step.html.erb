<% if @selected_enseigne.present? %>
<div class="booking-section">
  <h2 class="booking-section-title">2. Choisissez une prestation</h2>
  <p class="booking-section-meta">Sélectionnez le service qui vous convient.</p>

  <div class="slot-grid">
    <% @services.each do |service| %>
      <% selected = @selected_service&.id == service.id %>

      <%= form_with url: public_client_path(@client.slug), method: :get, local: true do %>
        <%= hidden_field_tag :enseigne_id, @selected_enseigne.id %>
        <%= hidden_field_tag :service_id, service.id %>
        <%= submit_tag service.name, class: ["slot-button", ("slot-button--selected" if selected)].compact.join(" ") %>
      <% end %>
    <% end %>
  </div>
</div>
<% end %>

